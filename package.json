{
  "name": "mpp-bazaar",
  "version": "1.0.0",
  "description": "Food truck ordering API with dynamic pricing powered by the Machine Payments Protocol",
  "scripts": {
    "build:client": "esbuild src/client-pay.ts --bundle --format=iife --platform=browser --outfile=public/client.js --minify",
    "build": "npm run build:client",
    "dev": "npm run build:client && wrangler dev --port 8787",
    "deploy": "npm run build:client && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "mppx": "^0.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
